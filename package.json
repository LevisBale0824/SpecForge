{
  "name": "specforge",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller"
    ]
  },
  "scripts": {
    "dev": "vite",
    "electron:dev": "cross-env ELECTRON=true vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,jsx,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,js,jsx,json,md,css,yml,yaml}\"",
    "prepare": "husky || true",
    "electron:build": "vue-tsc --noEmit && cross-env ELECTRON=true vite build && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder",
    "gen:icons": "node scripts/gen-icons.mjs",
    "bridge:build": "tsc -p cli-bridge/tsconfig.json",
    "bridge:start": "node cli-bridge/dist/server.js"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.specforge.app",
    "productName": "SpecForge",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "LevisBale0824",
      "repo": "SpecForge",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "electron-updater": "^6.8.9",
    "vue": "^3.5.28",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@shikijs/markdown-it": "^4.2.0",
    "@shikijs/transformers": "^4.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.2.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "markdown-it": "^14.2.0",
    "prettier": "^3.4.2",
    "sharp": "^0.35.1",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.4"
  }
}
